{
  "name": "obsidian-inbox-processor",
  "version": "0.1.0",
  "description": "Obsidian plugin to classify and move Inbox notes with keyword-based folder recommendations",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "devDependencies": {
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.2",
    "obsidian": "^1.11.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
