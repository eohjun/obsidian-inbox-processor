{
	"name": "obsidian-inbox-processor",
	"version": "0.2.12",
	"description": "Obsidian plugin to classify and move Inbox notes with hybrid keyword + LLM folder recommendations",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck"
	},
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.27.2",
		"obsidian": "^1.11.0",
		"obsidian-llm-shared": "github:eohjun/obsidian-llm-shared#v1.3.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2"
	},
	"license": "MIT"
}
